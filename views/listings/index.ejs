<% layout("/layouts/boilerplate") %>

<!-- Filter Bar -->
<div class="filter-bar" role="navigation" aria-label="Category filters">
  <% for (const f of FILTERS) { %>
    <a
      href="/listings?filter=<%= f.slug %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %><%= sortBy !== 'newest' ? '&sort=' + sortBy : '' %>"
      class="filter-item <%= currentFilter === f.slug ? 'active' : '' %>"
      aria-label="<%= f.label %>"
      aria-current="<%= currentFilter === f.slug ? 'page' : 'false' %>"
    >
      <i class="fa-solid <%= f.icon %>"></i>
      <span><%= f.label %></span>
    </a>
  <% } %>

  <div class="filter-bar-divider"></div>

  <!-- Tax toggle -->
  <div class="tax-toggle-wrap">
    <label class="toggle-switch" for="taxSwitch" aria-label="Toggle taxes">
      <input type="checkbox" id="taxSwitch" />
      <span class="toggle-track"></span>
    </label>
    <span>Show total with taxes</span>
  </div>
</div>

<!-- Sort + Search info bar -->
<div class="index-toolbar">
  <% if (searchQuery) { %>
    <span class="index-toolbar-info">
      Results for <strong>"<%= searchQuery %>"</strong>
      &mdash; <a href="/listings">Clear search</a>
    </span>
  <% } else { %>
    <span class="index-toolbar-info"><%= totalListings %> listing<%= totalListings !== 1 ? 's' : '' %></span>
  <% } %>

  <div class="sort-select-wrap">
    <label for="sortSelect"><i class="fa-solid fa-arrow-down-wide-short"></i></label>
    <select id="sortSelect">
      <%
        function sortUrl(val) {
          let u = '/listings?sort=' + val;
          if (searchQuery) u += '&q=' + encodeURIComponent(searchQuery);
          if (currentFilter !== 'trending') u += '&filter=' + currentFilter;
          return u;
        }
      %>
      <option value="<%= sortUrl('newest') %>"    <%= sortBy === 'newest'    ? 'selected' : '' %>>Newest</option>
      <option value="<%= sortUrl('oldest') %>"    <%= sortBy === 'oldest'    ? 'selected' : '' %>>Oldest</option>
      <option value="<%= sortUrl('price_low') %>" <%= sortBy === 'price_low' ? 'selected' : '' %>>Price: Low to High</option>
      <option value="<%= sortUrl('price_high') %>"<%= sortBy === 'price_high'? 'selected' : '' %>>Price: High to Low</option>
    </select>
  </div>
</div>

<!-- Listings Grid -->
<div class="listings-grid">
  <% for (let listing of allListings) { %>
    <div class="listing-card-wrap">
      <% if (currUser) { %>
        <button
          class="wishlist-btn <%= currUser.wishlist && currUser.wishlist.map(String).includes(String(listing._id)) ? 'wishlisted' : '' %>"
          data-listing-id="<%= listing._id %>"
          data-csrf="<%= csrfToken %>"
          aria-label="Toggle wishlist"
        >
          <i class="fa-<%= currUser.wishlist && currUser.wishlist.map(String).includes(String(listing._id)) ? 'solid' : 'regular' %> fa-heart"></i>
        </button>
      <% } %>
      <a href="/listings/<%= listing._id %>" class="listing-card" aria-label="<%= listing.title %>">
        <div class="listing-card-inner">
          <div class="listing-card-img-wrap">
            <img
              src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : '' %>"
              alt="<%= listing.title %>"
              loading="lazy"
            />
            <span class="listing-card-badge"><%= listing.country %></span>
          </div>
          <div class="listing-card-body">
            <div class="listing-card-title"><%= listing.title %></div>
            <div class="listing-card-location">
              <i class="fa-solid fa-location-dot" style="font-size:0.7rem;margin-right:3px"></i>
              <%= listing.location %>
            </div>
            <div class="listing-card-price">
              &#8377;<%= listing.price.toLocaleString("en-IN") %>
              <span>/ night</span>
              <span class="tax-amount" style="display:none;color:var(--sand);font-size:0.8rem">
                &nbsp;+&#8377;<%= Math.round(listing.price * 0.18).toLocaleString("en-IN") %> GST
              </span>
            </div>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<% if (allListings.length === 0) { %>
  <div style="text-align:center;padding:6rem 2rem;color:var(--charcoal-60)">
    <i class="fa-regular fa-compass" style="font-size:3rem;margin-bottom:1rem;display:block;color:var(--charcoal-20)"></i>
    <p style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:0.5rem">No listings found</p>
    <% if (searchQuery) { %>
      <p style="font-size:0.875rem">
        No results for "<strong><%= searchQuery %></strong>".
        <a href="/listings" style="color:var(--terra)">Browse all listings</a>.
      </p>
    <% } else { %>
      <p style="font-size:0.875rem">
        Be the first to <a href="/listings/new" style="color:var(--terra)">add one</a>.
      </p>
    <% } %>
  </div>
<% } %>

<!-- Pagination -->
<% if (totalPages > 1) { %>
  <nav class="pagination" aria-label="Listing pages">
    <%
      function pageUrl(p) {
        let u = '/listings?page=' + p;
        if (searchQuery) u += '&q=' + encodeURIComponent(searchQuery);
        if (currentFilter !== 'trending') u += '&filter=' + currentFilter;
        if (sortBy !== 'newest') u += '&sort=' + sortBy;
        return u;
      }
    %>
    <% if (currentPage > 1) { %>
      <a href="<%= pageUrl(currentPage - 1) %>" class="page-btn">&laquo; Prev</a>
    <% } %>

    <% for (let p = 1; p <= totalPages; p++) { %>
      <% if (p === 1 || p === totalPages || (p >= currentPage - 2 && p <= currentPage + 2)) { %>
        <a href="<%= pageUrl(p) %>" class="page-btn <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
      <% } else if (p === currentPage - 3 || p === currentPage + 3) { %>
        <span class="page-dots">&hellip;</span>
      <% } %>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="<%= pageUrl(currentPage + 1) %>" class="page-btn">Next &raquo;</a>
    <% } %>
  </nav>
<% } %>
