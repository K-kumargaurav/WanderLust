<% layout("/layouts/boilerplate") %>

<div class="form-page">
  <div style="margin-bottom:0.25rem">
    <a href="/listings" style="font-size:0.8rem;color:var(--sand);text-decoration:none;display:inline-flex;align-items:center;gap:0.3rem">
      <i class="fa-solid fa-arrow-left" style="font-size:0.7rem"></i> Back to listings
    </a>
  </div>
  <h1 class="form-page-title">Add a new listing</h1>
  <p class="form-page-subtitle">Share your space with travellers from around the world.</p>

  <div class="form-card">
    <form
      id="newListingForm"
      action="/listings"
      method="POST"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <!-- Title -->
      <div class="form-group">
        <label for="title" class="form-label">Title</label>
        <input
          id="title"
          type="text"
          name="listing[title]"
          class="form-control"
          placeholder="e.g. Cozy loft in the old quarter"
          required
        />
        <div class="invalid-feedback">Title is required.</div>
      </div>

      <!-- Description -->
      <div class="form-group">
        <label for="description" class="form-label">Description</label>
        <textarea
          id="description"
          name="listing[description]"
          class="form-control"
          placeholder="Describe your space — what makes it special?"
          rows="4"
          required
        ></textarea>
        <div class="invalid-feedback">Description is required.</div>
      </div>

      <!-- Image Upload (up to 3) -->
      <div class="form-group">
        <label for="images" class="form-label">Listing Photos <span style="color:var(--sand);font-weight:400;text-transform:none">(up to 3)</span></label>
        <input
          id="images"
          type="file"
          name="listing[images]"
          class="form-control form-control-file"
          accept="image/png, image/jpeg, image/jpg"
          multiple
          required
        />
        <p style="font-size:0.75rem;color:var(--sand);margin-top:0.3rem">
          Accepted: JPG, JPEG, PNG &mdash; max 5 MB each, up to 3 photos
        </p>
        <!-- Image previews -->
        <div id="imagePreviewContainer" class="image-preview-grid"></div>
      </div>

      <!-- Price + Country -->
      <div class="form-row">
        <div class="form-group">
          <label for="price" class="form-label">Price (&#8377;/night)</label>
          <input
            id="price"
            type="number"
            name="listing[price]"
            class="form-control"
            placeholder="e.g. 4500"
            min="0"
            required
          />
          <div class="invalid-feedback">Enter a valid price.</div>
        </div>
        <div class="form-group">
          <label for="country" class="form-label">Country</label>
          <input
            id="country"
            type="text"
            name="listing[country]"
            class="form-control"
            placeholder="e.g. India"
            required
          />
          <div class="invalid-feedback">Country is required.</div>
        </div>
      </div>

      <!-- Location -->
      <div class="form-group">
        <label for="location" class="form-label">Location / City</label>
        <input
          id="location"
          type="text"
          name="listing[location]"
          class="form-control"
          placeholder="e.g. Jaipur, Rajasthan"
          required
        />
        <div class="invalid-feedback">Location is required.</div>
      </div>

      <!-- Category -->
      <div class="form-group">
        <label for="category" class="form-label">Category <span style="color:var(--sand);font-weight:400;text-transform:none">(optional)</span></label>
        <select id="category" name="listing[category]" class="form-control">
          <option value="">— None —</option>
          <% for (const cat of categories) { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% } %>
        </select>
      </div>

      <div style="display:flex;gap:0.75rem;align-items:center;margin-top:0.5rem">
        <button type="button" class="btn btn-outline" id="previewBtn">
          <i class="fa-solid fa-eye"></i> Preview
        </button>
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-plus"></i> Add Listing
        </button>
        <a href="/listings" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</div>

<!-- Preview Modal -->
<div id="previewModal" class="preview-modal" style="display:none">
  <div class="preview-modal-content">
    <div class="preview-modal-header">
      <h2 style="font-family:var(--font-display);font-weight:400;font-size:1.5rem">Listing Preview</h2>
      <button type="button" class="preview-modal-close" id="closePreview">&times;</button>
    </div>
    <div class="preview-modal-body">
      <div id="previewImages" class="preview-images"></div>
      <h3 id="previewTitle" style="font-family:var(--font-display);font-size:1.75rem;font-weight:400;margin:1rem 0 0.5rem"></h3>
      <p id="previewLocation" style="color:var(--charcoal-60);font-size:0.875rem;margin-bottom:1rem">
        <i class="fa-solid fa-location-dot" style="color:var(--terra);margin-right:4px"></i>
      </p>
      <p id="previewDescription" style="line-height:1.75;margin-bottom:1rem"></p>
      <div style="display:flex;gap:1rem;align-items:center">
        <span id="previewPrice" style="font-family:var(--font-display);font-size:1.5rem"></span>
        <span id="previewCategory" class="listing-card-badge" style="position:static"></span>
      </div>
    </div>
    <div class="preview-modal-footer">
      <button type="button" class="btn btn-outline" id="closePreview2">Edit</button>
      <button type="button" class="btn btn-primary" id="confirmSubmit">
        <i class="fa-solid fa-check"></i> Confirm &amp; Create
      </button>
    </div>
  </div>
</div>
