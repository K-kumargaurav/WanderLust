<nav class="wl-nav">
  <div class="inner">
    <a href="/listings" class="wl-brand">
      <div class="wl-brand-icon">
        <i class="fa-regular fa-compass"></i>
      </div>
      <span class="wl-brand-name">WanderLust</span>
    </a>

    <%
      /**
       * currentFilter and searchQuery are always present via res.locals defaults
       * set in app.js, so no typeof guard is needed here.
       */
    %>
    <form class="wl-search" action="/listings" method="GET" role="search">
      <%-- Preserve the active category filter across searches --%>
      <% if (currentFilter && currentFilter !== "trending") { %>
        <input type="hidden" name="filter" value="<%= currentFilter %>" />
      <% } %>
      <i class="fa-solid fa-magnifying-glass wl-search-icon"></i>
      <input
        type="search"
        name="q"
        placeholder="Search destinations…"
        autocomplete="off"
        value="<%= searchQuery %>"
        aria-label="Search listings"
      />
      <button type="submit" class="wl-search-btn">Search</button>
    </form>

    <button class="wl-nav-toggle" id="wl-nav-toggle" aria-label="Menu">
      <i class="fa-solid fa-bars"></i>
    </button>

    <div class="wl-nav-links" id="wl-nav-links">
      <a href="/listings" class="wl-nav-link">Explore</a>
      <% if (!currUser) { %>
        <a href="/signup" class="wl-nav-btn outline">Sign Up</a>
        <a href="/login"  class="wl-nav-btn">Log In</a>
      <% } else { %>
        <a href="/listings/new" class="wl-nav-link">Add Listing</a>
        <a href="/logout" class="wl-nav-btn outline">Log Out</a>
      <% } %>
    </div>
  </div>
</nav>