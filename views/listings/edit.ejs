<% layout("/layouts/boilerplate") %>

<div class="form-page">
  <div style="margin-bottom:0.25rem">
    <a href="/listings/<%= listing._id %>" style="font-size:0.8rem;color:var(--sand);text-decoration:none;display:inline-flex;align-items:center;gap:0.3rem">
      <i class="fa-solid fa-arrow-left" style="font-size:0.7rem"></i> Back to listing
    </a>
  </div>
  <h1 class="form-page-title">Edit Listing</h1>

  <div class="form-card">
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      enctype="multipart/form-data"
      class="needs-validation"
      novalidate
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="form-group">
        <label class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          class="form-control"
          value="<%= listing.title %>"
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          required
        ><%= listing.description %></textarea>
      </div>

      <!-- Current Images -->
      <% if (listing.images && listing.images.length > 0) { %>
        <div class="form-group">
          <label class="form-label">Current Images</label>
          <div class="edit-images-grid">
            <% for (const img of listing.images) { %>
              <div class="edit-image-item">
                <img src="<%= img.url.replace('/upload', '/upload/w_250') %>" class="rounded" style="height:120px;object-fit:cover" />
                <label class="edit-image-delete">
                  <input type="checkbox" name="deleteImages[]" value="<%= img.filename %>" />
                  <span>Remove</span>
                </label>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- Upload New Images -->
      <div class="form-group">
        <label class="form-label">Add New Images <span style="color:var(--sand);font-weight:400;text-transform:none">(up to 3 total)</span></label>
        <input
          type="file"
          name="listing[images]"
          class="form-control form-control-file"
          accept="image/png, image/jpeg, image/jpg"
          multiple
        />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Price (&#8377;/night)</label>
          <input
            type="number"
            name="listing[price]"
            class="form-control"
            value="<%= listing.price %>"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            class="form-control"
            value="<%= listing.country %>"
            required
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          class="form-control"
          value="<%= listing.location %>"
          required
        />
      </div>

      <!-- Category -->
      <div class="form-group">
        <label class="form-label">Category <span style="color:var(--sand);font-weight:400;text-transform:none">(optional)</span></label>
        <select name="listing[category]" class="form-control">
          <option value="">— None —</option>
          <% for (const cat of categories) { %>
            <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% } %>
        </select>
      </div>

      <div style="display:flex;gap:0.75rem;margin-top:0.5rem">
        <button type="submit" class="btn btn-primary">Update Listing</button>
        <a href="/listings/<%= listing._id %>" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</div>
