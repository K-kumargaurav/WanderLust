<% layout("/layouts/boilerplate") %>

<!-- Safe data bridge for map.js -->
<div id="map-data"
     data-token="<%= mapToken %>"
     data-listing="<%= encodeURIComponent(JSON.stringify(listing)) %>"
     style="display:none"
     aria-hidden="true">
</div>

<!-- Hero -->
<div class="show-hero">
  <h1 class="show-hero-title"><%= listing.title %></h1>
  <div class="show-hero-meta">
    <span>
      <i class="fa-solid fa-location-dot" style="color:var(--terra);margin-right:4px"></i>
      <%= listing.location %>, <%= listing.country %>
    </span>
    <% if(listing.reviews && listing.reviews.length > 0) { %>
      <span class="dot">·</span>
      <span>
        <i class="fa-solid fa-star" style="color:var(--terra);margin-right:3px;font-size:0.8rem"></i>
        <%= (listing.reviews.reduce((sum, r) => sum + r.rating, 0) / listing.reviews.length).toFixed(1) %>
        &nbsp;<span style="color:var(--sand)">(<%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %>)</span>
      </span>
    <% } %>
    <% if (listing.category) { %>
      <span class="dot">·</span>
      <span class="show-category-pill">
        <i class="fa-solid fa-tag" style="margin-right:4px;font-size:0.75rem"></i>
        <%= listing.category %>
      </span>
    <% } %>
  </div>

  <!-- Image Gallery -->
  <% if (listing.images && listing.images.length >= 2) { %>
    <div class="show-gallery-grid show-gallery-<%= Math.min(listing.images.length, 3) %>">
      <div class="show-gallery-primary">
        <img src="<%= listing.images[0].url %>" alt="<%= listing.title %>" />
      </div>
      <div class="show-gallery-secondary">
        <img src="<%= listing.images[1].url %>" alt="<%= listing.title %> photo 2" />
        <% if (listing.images.length >= 3) { %>
          <img src="<%= listing.images[2].url %>" alt="<%= listing.title %> photo 3" />
        <% } %>
      </div>
    </div>
  <% } else { %>
    <img
      src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : '' %>"
      alt="<%= listing.title %>"
      class="show-hero-img"
    />
  <% } %>
</div>

<!-- Two-column layout -->
<div class="show-layout">

  <!-- Left: Details + Reviews -->
  <div class="show-main">

    <!-- Owner -->
    <div class="show-owner-row">
      <div class="show-avatar">
        <%= listing.owner ? listing.owner.username.charAt(0).toUpperCase() : '?' %>
      </div>
      <div class="show-owner-text">
        <div class="show-owner-label">Hosted by</div>
        <div class="show-owner-name"><%= listing.owner ? listing.owner.username : 'Unknown' %></div>
      </div>
    </div>

    <!-- Description -->
    <p class="show-description"><%= listing.description %></p>

    <!-- Details -->
    <div class="show-details-grid">
      <div class="show-detail-item">
        <div class="show-detail-label"><i class="fa-solid fa-location-dot"></i> Location</div>
        <div class="show-detail-value"><%= listing.location %></div>
      </div>
      <div class="show-detail-item">
        <div class="show-detail-label"><i class="fa-solid fa-globe"></i> Country</div>
        <div class="show-detail-value"><%= listing.country %></div>
      </div>
      <div class="show-detail-item">
        <div class="show-detail-label"><i class="fa-solid fa-indian-rupee-sign"></i> Price</div>
        <div class="show-detail-value">&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</div>
      </div>
      <% if (listing.category) { %>
        <div class="show-detail-item">
          <div class="show-detail-label"><i class="fa-solid fa-tag"></i> Category</div>
          <div class="show-detail-value"><%= listing.category %></div>
        </div>
      <% } %>
    </div>

    <!-- Owner Actions -->
    <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
      <div class="show-actions">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline">
          <i class="fa-regular fa-pen-to-square"></i> Edit Listing
        </a>
        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-danger">
            <i class="fa-regular fa-trash-can"></i> Delete
          </button>
        </form>
      </div>
    <% } %>

    <!-- Reviews -->
    <div class="reviews-section">
      <h2 class="reviews-section-title">
        <% if(listing.reviews && listing.reviews.length > 0) { %>
          <%= listing.reviews.length %> Review<%= listing.reviews.length !== 1 ? 's' : '' %>
        <% } else { %>
          Reviews
        <% } %>
      </h2>

      <!-- Leave a Review Form -->
      <% if(currUser) { %>
        <div class="review-form-card">
          <h3 class="review-form-heading">Share your experience</h3>
          <form
            action="/listings/<%= listing.id %>/reviews"
            method="POST"
            novalidate
            class="needs-validation"
          >
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <!-- Star Rating -->
            <div class="form-group">
              <label class="form-label">Your Rating</label>
              <div class="star-rating-input" role="radiogroup" aria-label="Star rating">
                <input type="radio" id="star5" name="review[rating]" value="5" required />
                <label for="star5" title="Amazing">&#9733;</label>
                <input type="radio" id="star4" name="review[rating]" value="4" />
                <label for="star4" title="Very good">&#9733;</label>
                <input type="radio" id="star3" name="review[rating]" value="3" />
                <label for="star3" title="Average">&#9733;</label>
                <input type="radio" id="star2" name="review[rating]" value="2" />
                <label for="star2" title="Not good">&#9733;</label>
                <input type="radio" id="star1" name="review[rating]" value="1" />
                <label for="star1" title="Terrible">&#9733;</label>
              </div>
            </div>

            <!-- Comment -->
            <div class="form-group">
              <label for="comment" class="form-label">Your Comment</label>
              <textarea
                id="comment"
                name="review[comment]"
                class="form-control"
                rows="3"
                placeholder="What did you love about this place?"
                required
              ></textarea>
              <div class="invalid-feedback">Please write a comment before submitting.</div>
            </div>

            <button type="submit" class="btn btn-primary">
              <i class="fa-solid fa-paper-plane"></i> Post Review
            </button>
          </form>
        </div>
      <% } else { %>
        <div style="background:var(--ivory-dark);border-radius:var(--radius-md);padding:1.25rem;margin-bottom:1.5rem;text-align:center;font-size:0.875rem;color:var(--charcoal-60)">
          <a href="/login" style="color:var(--terra);font-weight:600">Log in</a> to leave a review
        </div>
      <% } %>

      <!-- Reviews List -->
      <% if(listing.reviews && listing.reviews.length > 0) { %>
        <div class="reviews-grid">
          <% for(let review of listing.reviews) { %>
            <div class="review-card" id="review-<%= review._id %>">

              <!-- Review actions (only for review author) -->
              <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                <div class="review-actions">
                  <button class="review-edit-btn" title="Edit review" data-review-id="<%= review._id %>">
                    <i class="fa-solid fa-pen"></i>
                  </button>
                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" style="display:inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="review-delete-btn" title="Delete review">
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                  </form>
                </div>
              <% } %>

              <div class="review-author">
                @<%= review.author ? review.author.username : 'Anonymous' %>
              </div>

              <!-- Star display -->
              <div class="star-display-group" id="stars-<%= review._id %>">
                <% for(let i = 1; i <= 5; i++) { %>
                  <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                <% } %>
              </div>

              <p class="review-comment" id="comment-<%= review._id %>"><%= review.comment %></p>

              <!-- Inline edit form (hidden by default) -->
              <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                <form
                  class="review-edit-form"
                  id="edit-form-<%= review._id %>"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=PUT"
                  method="POST"
                  style="display:none"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="form-group">
                    <label class="form-label">Rating</label>
                    <select name="review[rating]" class="form-control" style="width:auto">
                      <% for (let i = 5; i >= 1; i--) { %>
                        <option value="<%= i %>" <%= i === review.rating ? 'selected' : '' %>><%= i %> star<%= i > 1 ? 's' : '' %></option>
                      <% } %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Comment</label>
                    <textarea name="review[comment]" class="form-control" rows="2" required><%= review.comment %></textarea>
                  </div>
                  <div style="display:flex;gap:0.5rem">
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    <button type="button" class="btn btn-outline btn-sm review-cancel-btn" data-review-id="<%= review._id %>">Cancel</button>
                  </div>
                </form>
              <% } %>

            </div>
          <% } %>
        </div>
      <% } else { %>
        <p style="color:var(--sand);font-size:0.875rem">No reviews yet. Be the first!</p>
      <% } %>
    </div>
  </div>

  <!-- Right: Price Card + Map -->
  <div class="show-sidebar">

    <!-- Price Card -->
    <div class="price-card" data-price="<%= listing.price %>">
      <div class="price-card-amount">
        &#8377;<%= listing.price.toLocaleString("en-IN") %>
        <em>/ night</em>
      </div>
      <div class="price-card-location">
        <i class="fa-solid fa-location-dot" style="margin-right:4px"></i>
        <%= listing.location %>, <%= listing.country %>
      </div>
      <% if(currUser) { %>
        <form id="bookingForm" action="/listings/<%= listing._id %>/bookings" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="booking-date-grid">
            <div class="booking-date-field">
              <label for="checkIn" class="booking-date-label">Check-in</label>
              <input
                type="text"
                name="booking[checkIn]"
                id="checkIn"
                placeholder="Select dates"
                class="form-control"
                required
                readonly
              />
            </div>
            <div class="booking-date-field">
              <label class="booking-date-label">Check-out</label>
              <input type="hidden" name="booking[checkOut]" id="checkOut" />
              <input
                type="text"
                id="checkOutDisplay"
                class="form-control"
                placeholder="—"
                readonly
                tabindex="-1"
              />
            </div>
          </div>

          <div id="booking-summary" class="booking-summary" style="display:none">
            <div class="booking-summary-row">
              <span id="summary-subtotal-label"></span>
              <span id="summary-subtotal-value"></span>
            </div>
            <div class="booking-summary-row" style="color:var(--charcoal-60)">
              <span>GST (18%)</span>
              <span id="summary-gst-value"></span>
            </div>
            <hr style="border:none;border-top:1px solid var(--charcoal-20);margin:0.4rem 0" />
            <div class="booking-summary-row" style="font-weight:600">
              <span>Total</span>
              <span id="summary-total"></span>
            </div>
          </div>

          <button type="submit" class="btn-reserve" id="booking-submit" disabled>
            Confirm Booking
          </button>
        </form>
        <p style="font-size:0.72rem;color:var(--sand);text-align:center;margin-top:0.75rem">
          You won't be charged yet
        </p>
      <% } else { %>
        <a href="/login" class="btn-reserve" style="display:block;text-align:center;text-decoration:none">
          Log in to Reserve
        </a>
        <p style="font-size:0.72rem;color:var(--sand);text-align:center;margin-top:0.75rem">
          You won't be charged yet
        </p>
      <% } %>
    </div>

    <!-- Map -->
    <div class="map-card">
      <div class="map-card-header">
        <i class="fa-solid fa-map-pin" style="color:var(--terra);margin-right:6px"></i>
        Where you'll be
      </div>
      <div id="map"></div>
    </div>

  </div>
</div>

<% if(currUser) { %>
<style>
  /* ─── Booking date picker ─────────────────────────────────────── */
  .booking-date-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .booking-date-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--charcoal-60);
    margin-bottom: 0.3rem;
  }
  .booking-date-field .form-control {
    font-size: 0.85rem;
    cursor: pointer;
  }
  .booking-summary {
    background: var(--ivory-dark);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
  }
  .booking-summary-row {
    display: flex;
    justify-content: space-between;
    color: var(--charcoal);
  }
  .booking-summary-row #summary-total {
    font-weight: 600;
  }
  .btn-reserve:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* ─── Flatpickr terra theme overrides ─────────────────────────── */
  .flatpickr-day.selected,
  .flatpickr-day.startRange,
  .flatpickr-day.endRange,
  .flatpickr-day.selected.inRange,
  .flatpickr-day.startRange.inRange,
  .flatpickr-day.endRange.inRange,
  .flatpickr-day.selected:focus,
  .flatpickr-day.startRange:focus,
  .flatpickr-day.endRange:focus,
  .flatpickr-day.selected:hover,
  .flatpickr-day.startRange:hover,
  .flatpickr-day.endRange:hover,
  .flatpickr-day.selected.prevMonthDay,
  .flatpickr-day.startRange.prevMonthDay,
  .flatpickr-day.endRange.prevMonthDay,
  .flatpickr-day.selected.nextMonthDay,
  .flatpickr-day.startRange.nextMonthDay,
  .flatpickr-day.endRange.nextMonthDay {
    background: var(--terra);
    border-color: var(--terra);
  }
  .flatpickr-day.inRange {
    background: var(--terra-pale);
    border-color: var(--terra-pale);
    box-shadow: -5px 0 0 var(--terra-pale), 5px 0 0 var(--terra-pale);
  }
  .flatpickr-day.today {
    border-color: var(--terra-light);
  }
  .flatpickr-day.today:hover {
    background: var(--terra-pale);
    border-color: var(--terra-light);
  }
</style>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const checkInInput    = document.getElementById("checkIn");
    if (!checkInInput || typeof flatpickr === "undefined") return;

    const checkOutInput       = document.getElementById("checkOut");
    const checkOutDisplay     = document.getElementById("checkOutDisplay");
    const summary             = document.getElementById("booking-summary");
    const summarySubLabel     = document.getElementById("summary-subtotal-label");
    const summarySubValue     = document.getElementById("summary-subtotal-value");
    const summaryGstValue     = document.getElementById("summary-gst-value");
    const summaryTotal        = document.getElementById("summary-total");
    const submitBtn           = document.getElementById("booking-submit");
    const pricePerNight       = Number(document.querySelector(".price-card").dataset.price);
    const GST_RATE            = 0.18;

    function formatDate(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    const bookingForm = document.getElementById("bookingForm");
    const listingTitle = bookingForm.closest(".price-card")
      .querySelector(".price-card-amount").textContent.trim();

    bookingForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const checkIn  = checkInInput.value;
      const checkOut = checkOutInput.value;
      const nights   = Number(bookingForm.dataset.nights);
      const total    = Number(bookingForm.dataset.total);

      const confirmed = await showConfirmModal(
        "Confirm your booking",
        `<strong><%= listing.title.replace(/'/g, "\\'") %></strong><br><br>` +
        `Check-in: <strong>${checkIn}</strong><br>` +
        `Check-out: <strong>${checkOut}</strong><br>` +
        `Duration: <strong>${nights} night${nights > 1 ? "s" : ""}</strong><br><br>` +
        `Total (incl. GST): <strong>\u20b9${total.toLocaleString("en-IN")}</strong>`,
        "Confirm Booking",
        "btn-primary"
      );

      if (confirmed) e.target.submit();
    });

    flatpickr(checkInInput, {
      mode: "range",
      minDate: "today",
      dateFormat: "Y-m-d",
      showMonths: 1,
      onChange(selectedDates) {
        if (selectedDates.length === 2) {
          const ciStr = formatDate(selectedDates[0]);
          const coStr = formatDate(selectedDates[1]);

          checkInInput.value  = ciStr;
          checkOutInput.value = coStr;
          checkOutDisplay.value = coStr;

          const nights   = Math.ceil(
            (selectedDates[1] - selectedDates[0]) / (1000 * 60 * 60 * 24)
          );
          const subtotal = nights * pricePerNight;
          const gst      = Math.round(subtotal * GST_RATE);
          const total    = subtotal + gst;

          summarySubLabel.textContent = `\u20b9${pricePerNight.toLocaleString("en-IN")} \u00d7 ${nights} night${nights === 1 ? "" : "s"}`;
          summarySubValue.textContent = `\u20b9${subtotal.toLocaleString("en-IN")}`;
          summaryGstValue.textContent = `\u20b9${gst.toLocaleString("en-IN")}`;
          summaryTotal.textContent    = `\u20b9${total.toLocaleString("en-IN")}`;
          summary.style.display       = "block";
          submitBtn.disabled          = false;

          // Store for confirmation modal
          const form = document.getElementById("bookingForm");
          form.dataset.nights = nights;
          form.dataset.total  = total;
        } else {
          checkOutInput.value     = "";
          checkOutDisplay.value   = "";
          summary.style.display   = "none";
          submitBtn.disabled      = true;
        }
      },
    });
  });
</script>
<% } %>

<script src="/js/map.js"></script>
