<% layout("/layouts/boilerplate") %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card-header">
      <div class="auth-logo">
        <i class="fa-solid fa-key"></i>
      </div>
      <h1 class="auth-title">Forgot password?</h1>
      <p class="auth-subtitle">Enter your email and we'll send you a reset link</p>
    </div>

    <form action="/forgot-password" method="POST" class="needs-validation" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="form-group">
        <label for="email" class="form-label">Email</label>
        <input
          id="email"
          type="email"
          name="email"
          class="form-control"
          placeholder="you@example.com"
          required
          autocomplete="email"
          inputmode="email"
        />
        <div class="invalid-feedback">Please enter a valid email address.</div>
      </div>

      <button type="submit" class="btn btn-primary btn-full" style="margin-top:0.75rem">
        <i class="fa-solid fa-paper-plane"></i>&nbsp; Send Reset Link
      </button>
    </form>

    <p class="auth-footer-text" style="margin-top:1.25rem">
      Remember your password? <a href="/login">Log in</a>
    </p>
  </div>
</div>
