<% layout("/layouts/boilerplate") %>

<div style="max-width:1320px;margin:2rem auto;padding:0 2rem 4rem">
  <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:400;margin-bottom:0.5rem">
    <i class="fa-solid fa-heart" style="color:var(--terra);margin-right:0.5rem"></i>
    Your Wishlist
  </h1>
  <p style="color:var(--charcoal-60);font-size:0.875rem;margin-bottom:2rem">
    <%= wishlistListings.length %> saved listing<%= wishlistListings.length !== 1 ? 's' : '' %>
  </p>

  <% if (wishlistListings.length > 0) { %>
    <div class="listings-grid" style="padding:0">
      <% for (const listing of wishlistListings) { %>
        <div class="listing-card-wrap">
          <button
            class="wishlist-btn wishlisted"
            data-listing-id="<%= listing._id %>"
            data-csrf="<%= csrfToken %>"
            aria-label="Remove from wishlist"
          >
            <i class="fa-solid fa-heart"></i>
          </button>
          <a href="/listings/<%= listing._id %>" class="listing-card" aria-label="<%= listing.title %>">
            <div class="listing-card-inner">
              <div class="listing-card-img-wrap">
                <img
                  src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : '' %>"
                  alt="<%= listing.title %>"
                  loading="lazy"
                />
                <span class="listing-card-badge"><%= listing.country %></span>
              </div>
              <div class="listing-card-body">
                <div class="listing-card-title"><%= listing.title %></div>
                <div class="listing-card-location">
                  <i class="fa-solid fa-location-dot" style="font-size:0.7rem;margin-right:3px"></i>
                  <%= listing.location %>
                </div>
                <div class="listing-card-price">
                  &#8377;<%= listing.price.toLocaleString("en-IN") %>
                  <span>/ night</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <div style="text-align:center;padding:4rem 2rem;color:var(--charcoal-60)">
      <i class="fa-regular fa-heart" style="font-size:3rem;margin-bottom:1rem;display:block;color:var(--charcoal-20)"></i>
      <p style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:0.5rem">No saved listings</p>
      <p style="font-size:0.875rem">
        Start exploring and save listings you love.
        <a href="/listings" style="color:var(--terra)">Browse listings</a>.
      </p>
    </div>
  <% } %>
</div>
