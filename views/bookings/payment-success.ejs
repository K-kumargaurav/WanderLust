<% layout("/layouts/boilerplate") %>

<div style="min-height:calc(100vh - 68px);display:flex;
            align-items:center;justify-content:center;padding:2rem">
  <div style="text-align:center;max-width:480px">

    <div style="font-size:4rem;margin-bottom:1rem">&#x1F389;</div>

    <h1 style="font-family:var(--font-display);font-size:2rem;
               font-weight:400;margin-bottom:0.5rem">
      Payment Successful!
    </h1>

    <p style="color:var(--charcoal-60);margin-bottom:2rem;line-height:1.7">
      Your booking request has been sent to the host.
      You will be notified once the host confirms your stay.
    </p>

    <a href="/bookings" class="btn btn-primary">
      <i class="fa-regular fa-calendar-check"></i> View My Bookings
    </a>

  </div>
</div>
